@startuml
title University Academic Management System - Analytical Class Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho
hide circle

package "Users" {
  abstract class Person {
    id: Long
    name: String
    surname: String
    birthDate: BirthDate
    emails: Set<String>
    primaryEmail: String
    passwordHash: String
  }

  class Student {
    studentNumber: String
  }

  class Teacher {
    employeeNumber: String
    isQualifiedFor(subject): boolean
  }

  class Administrator {
    employeeNumber: String
  }

  class PersonEmail <<multi-value>> {
    email: String
  }

  Person <|-- Student
  Person <|-- Teacher
  Person <|-- Administrator
  Person "1" *-- "1..3" PersonEmail : emails
}

package "Academic Structure" {
  class Field {
    id: Long
    name: String
  }

  class Semester {
    id: Long
    number: int
    startDate: LocalDate
    endDate: LocalDate
  }

  class StudentGroup {
    id: Long
    code: String
  }

  class Subject {
    id: Long
    name: String
  }

  class SemesterFieldSubject <<association class>>

  Field "0..*" -- "1..*" Semester : academic periods
  Semester "1" -- "0..*" SemesterFieldSubject
  Field "1" -- "0..*" SemesterFieldSubject
  Subject "1" -- "0..*" SemesterFieldSubject : curriculum
  Semester "1" -- "0..*" StudentGroup : groups
  Field "1" -- "0..*" StudentGroup : field context
  StudentGroup "1" -- "0..*" Student : students
  Subject "0..*" -- "0..*" StudentGroup : assigned to
  Teacher "1..*" -- "1..5" Subject : qualified subjects
}

package "Scheduling And Attendance" {
  class WeeklyScheduleEntry {
    id: Long
    classType: ClassType
    meetingMode: MeetingMode
    dayOfWeek: DayOfWeek
    startTime: LocalTime
    endTime: LocalTime
    onlineMeetingLink: String
  }

  class ClassMeeting {
    id: Long
    meetingDate: LocalDate
    time: MeetingTime
    classType: ClassType
    meetingMode: MeetingMode
    status: ClassMeetingStatus
    location: String
    onlineMeetingLink: String
    comment: String
  }

  class Attendance {
    id: Long
    status: AttendanceStatus
    comment: String
  }

  class MeetingTime <<value object>> {
    dayOfWeek: DayOfWeek
    startTime: LocalTime
    endTime: LocalTime
  }

  Semester "1" -- "0..*" WeeklyScheduleEntry : has templates
  Field "1" -- "0..*" WeeklyScheduleEntry : field context
  StudentGroup "1" -- "0..*" WeeklyScheduleEntry : has
  Subject "1" -- "0..*" WeeklyScheduleEntry : planned subject
  Teacher "1" -- "0..*" WeeklyScheduleEntry : planned teacher
  WeeklyScheduleEntry "1" -- "0..*" ClassMeeting : generates

  StudentGroup "1" -- "0..*" ClassMeeting : assigned group
  Subject "1" -- "0..*" ClassMeeting : taught subject
  Teacher "1" -- "0..*" ClassMeeting : conducts
  ClassMeeting "1" *-- "0..*" Attendance : attendance records
  Student "1" -- "0..*" Attendance : receives
  ClassMeeting *-- MeetingTime : time
}

package "Rooms" {
  class Room {
    id: Long
    roomNumber: String
    capacity: int
    getBookingForSlot(slot)
    isAvailable(slot): boolean
  }

  class MeetingSlot <<qualifier>> {
    date: LocalDate
    startTime: LocalTime
    endTime: LocalTime
  }

  class RoomBooking {
    id: Long
    bookingStatus: BookingStatus
  }

  Room "1" -- "0..*" RoomBooking : bookingsBySlot [MeetingSlot]
  RoomBooking *-- "1" MeetingSlot : meetingSlot
  ClassMeeting "0..1" -- "0..1" RoomBooking : room booking
  WeeklyScheduleEntry "0..*" -- "0..1" Room : planned room
}

package "Reporting" {
  class AttendanceReport {
    id: Long
    generatedOn: LocalDate
    reportType: ReportType
    dateFrom: LocalDate
    dateTo: LocalDate
    classType: ClassType
    overallPerformancePercentage: double
    generateConclusionMessage(): String
  }

  class ReportLine {
    id: Long
    totalMeetings: int
    presentCount: int
    absentCount: int
    lateCount: int
    excusedCount: int
    attendancePercentage: double
  }

  AttendanceReport "1" *-- "0..*" ReportLine : report lines
  ReportLine "0..*" -- "1" Student : student
  AttendanceReport "0..*" -- "0..*" Semester : selected semesters
  AttendanceReport "0..*" -- "0..1" Teacher : teacher filter
  AttendanceReport "0..*" -- "0..1" Subject : subject filter
  AttendanceReport "0..*" -- "0..1" StudentGroup : group filter
}

package "Notifications" {
  abstract class Notification {
    id: Long
    title: String
    message: String
    priority: int
    status: NotificationStatus
    calculateDeliveryEffort(): int
  }

  class EmailNotification {
    hasAttachment: boolean
  }

  class SystemNotification {
    displaySeconds: int
  }

  class ScheduledNotificationTask {
    id: Long
    taskType: NotificationTaskType
    status: NotificationTaskStatus
    scheduledAt: LocalDateTime
    processedAt: LocalDateTime
    retryCount: int
    failureReason: String
  }

  Notification <|-- EmailNotification
  Notification <|-- SystemNotification
  Person "1" -- "0..*" Notification : recipient
  Person "1" -- "0..*" ScheduledNotificationTask : task recipient
  ClassMeeting "0..1" -- "0..*" ScheduledNotificationTask : meeting trigger
  AttendanceReport "0..1" -- "0..*" ScheduledNotificationTask : report trigger
}

package "Enumerations" {
  enum AttendanceStatus {
    PRESENT
    LATE
    ABSENT
    EXCUSED
  }

  enum BookingStatus {
    RESERVED
    CONFIRMED
    CANCELLED
  }

  enum ClassMeetingStatus {
    DRAFT
    SCHEDULED
    CANCELLED
    COMPLETED
  }

  enum ClassType {
    LECTURE
    TUTORIAL
    LABORATORY
  }

  enum MeetingMode {
    ONLINE
    CLASSROOM
  }

  enum NotificationStatus {
    DRAFT
    PENDING
    SENT
    FAILED
    CANCELLED
  }

  enum NotificationTaskStatus {
    PENDING
    PROCESSING
    SENT
    FAILED
    CANCELLED
  }

  enum NotificationTaskType {
    CLASS_MEETING_REMINDER
    LOW_ATTENDANCE_WARNING
    ATTENDANCE_REGISTERED
    ATTENDANCE_UPDATED
    REPORT_READY
  }

  enum ReportType {
    SEMESTER
    TEACHER
    SUBJECT
    GROUP
    COMBINED
  }
}

Attendance --> AttendanceStatus
RoomBooking --> BookingStatus
ClassMeeting --> ClassMeetingStatus
ClassMeeting --> ClassType
WeeklyScheduleEntry --> ClassType
ClassMeeting --> MeetingMode
WeeklyScheduleEntry --> MeetingMode
Notification --> NotificationStatus
ScheduledNotificationTask --> NotificationTaskStatus
ScheduledNotificationTask --> NotificationTaskType
AttendanceReport --> ReportType

note right of StudentGroup
MAS 4.2.4:
StudentGroup 1 -> 0..* Student.
The GUI screen displays students
through StudentGroup.getStudents().
end note

note right of Room
Qualified association:
Room [MeetingSlot] -> RoomBooking.
The same room cannot have two bookings
for the same date, start time, and end time.
end note

note right of Teacher
Teacher specialization is separate from
concrete class meetings.
Teacher-Subject = qualification.
Teacher-ClassMeeting = actual lesson.
end note

@enduml
