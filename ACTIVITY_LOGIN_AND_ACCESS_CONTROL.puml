@startuml
title Activity Diagram - Login And Role-Based Navigation

start

:User opens application;
:System displays LoginView;

repeat
  :User enters email and password;
  :User clicks Login;
  :AuthenticationService checks email in Person.emails;
  :PasswordService verifies password hash;

  if (Credentials valid?) then (yes)
    :SessionContext stores logged-in Person;
    :System opens MainLayout;
    :System displays logged-in name and role;

    if (Role?) then (Student)
      :Show common navigation;
      :Show Student pages;
      :Hide Teacher and Admin pages;
    elseif (Teacher)
      :Show common navigation;
      :Show Teacher pages;
      :Hide Student and Admin pages;
    else (Administrator)
      :Show common navigation;
      :Show Admin pages;
    endif

    :Default page = Public Weekly Schedule;
    stop
  else (no)
    :Show "Invalid email or password.";
  endif
repeat while (User tries again?) is (yes)

stop
@enduml
