@startuml
title University Academic Management System - Use Case Diagram

left to right direction
skinparam actorStyle awesome
skinparam linetype ortho

actor Student
actor Teacher
actor Administrator
actor SystemScheduler

rectangle "University Academic Management System" {
  usecase "Log into system" as Login
  usecase "View public weekly schedule" as PublicSchedule
  usecase "Manage personal settings\nand notifications" as Personal
  usecase "View personal schedule\nand history" as PersonalSchedule

  usecase "View group and classmates" as GroupView
  usecase "View assigned class meetings" as TeacherMeetings
  usecase "Create class meeting" as CreateMeeting
  usecase "Mark attendance" as MarkAttendance

  usecase "Manage class meetings\nand weekly schedules" as ManageMeetings
  usecase "Manage rooms and bookings" as ManageRooms
  usecase "Generate attendance report" as GenerateReport
  usecase "Export attendance report" as ExportReport
  usecase "Manage notifications" as ManageNotifications
  usecase "Open GroupStudentsAssociationView" as AssociationView

  usecase "Process scheduled\nnotification tasks" as SchedulerTasks
  usecase "Send automatic notifications" as AutoNotifications
}

Student --> Login
Student --> PublicSchedule
Student --> Personal
Student --> PersonalSchedule
Student --> GroupView

Teacher --> Login
Teacher --> PublicSchedule
Teacher --> Personal
Teacher --> TeacherMeetings
Teacher --> CreateMeeting
Teacher --> MarkAttendance
Teacher --> AssociationView

Administrator --> Login
Administrator --> PublicSchedule
Administrator --> Personal
Administrator --> ManageMeetings
Administrator --> ManageRooms
Administrator --> GenerateReport
Administrator --> ExportReport
Administrator --> ManageNotifications
Administrator --> MarkAttendance
Administrator --> AssociationView

SystemScheduler --> SchedulerTasks
SystemScheduler --> AutoNotifications

CreateMeeting .> ManageRooms : <<include>>\nroom availability
ExportReport .> GenerateReport : <<extend>>
AutoNotifications .> SchedulerTasks : <<include>>

note right of AssociationView
MAS 4.2.4 GUI:
ListView<StudentGroup> and TableView<Student>
using StudentGroup.getStudents().
end note

note bottom of MarkAttendance
Teacher must be assigned.
Meeting must not be cancelled.
Meeting start time must have passed.
end note

@enduml
