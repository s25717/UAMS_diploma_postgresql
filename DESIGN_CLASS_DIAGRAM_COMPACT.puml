@startuml
title Design Class Diagram - Readable Layered Implementation View

left to right direction
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 65
skinparam ranksep 55
hide circle

class "JavaFX GUI Layer" as GuiLayer <<layer>> {
  AttendanceGuiApp
  --
  Login view
  Main layout
  Public weekly schedule
  Class meeting details
  GroupStudentsAssociationView
  AdminWeeklyScheduleView
  AdminNotificationView
  AdminRoomManagementView
  AdminReportView
  --
  AttendanceRow
  ReportLineRow
}

class "Service Layer" as ServiceLayer <<layer>> {
  AuthenticationService
  PasswordService
  SessionContext
  PersonalSettingsService
  ScheduleAccessService
  ClassMeetingService
  AttendanceRegistrationService
  AttendanceReportService
  ReportExportService
  ScheduleGenerationService
  EntityService<T>
  RoomService
  RoomBookingService
  NotificationService
  NotificationManagementService
  SystemScheduler
}

class "Persistence Layer" as PersistenceLayer <<layer>> {
  JpaUtil
  JpaTransactionManager
  GenericRepository<T>
  PersonRepository
  StudentGroupRepository
  ClassMeetingRepository
  AttendanceRepository
  AttendanceReportRepository
  WeeklyScheduleEntryRepository
  RoomRepository
  RoomBookingRepository
  NotificationRepository
  ScheduledNotificationTaskRepository
}

class "Persistent Domain Model" as DomainLayer <<layer>> {
  Person
  Student
  Teacher
  Administrator
  StudentGroup
  Subject
  Semester
  WeeklyScheduleEntry
  ClassMeeting
  Attendance
  AttendanceReport
  ReportLine
  Room
  RoomBooking
  Notification
  ScheduledNotificationTask
}

GuiLayer --> ServiceLayer : calls services
ServiceLayer --> PersistenceLayer : uses repositories
PersistenceLayer --> DomainLayer : persists entities

class AuthenticationService {
  login(email, password)
  isStudent()
  isTeacher()
  isAdmin()
}

class AttendanceReportService {
  generateReport(filter)
  buildConclusionMessage(report)
}

class AttendanceRegistrationService {
  saveAttendance(meetingId, rows)
}

class ScheduleGenerationService {
  generateClassMeetingsForSemester(entry)
}

class RoomBookingService {
  createBooking(roomId, slot)
  isAvailable(roomId, slot)
}

class EntityService<T> {
  add(entity)
  update(entity)
  delete(id)
}

class RoomService {
  createRoom(roomNumber, capacity)
  updateRoom(room, roomNumber, capacity)
}

class NotificationManagementService {
  createSystemNotification()
  updateEditableNotification()
  cancelPendingNotification()
}

class JpaTransactionManager {
  execute(work)
  executeVoid(work)
}

class StudentGroupRepository {
  findAllWithStudents()
}

class ClassMeetingRepository {
  findClassMeetingsForCurrentWeek()
  findByReportFilter(filter)
}

class AttendanceRepository {
  findByClassMeetingIds(ids)
}

class GenericRepository<T> {
  findById()
  findAll()
  save()
  update()
  delete()
}

ServiceLayer .. AuthenticationService
ServiceLayer .. AttendanceReportService
ServiceLayer .. AttendanceRegistrationService
ServiceLayer .. ScheduleGenerationService
ServiceLayer .. EntityService
ServiceLayer .. RoomService
ServiceLayer .. RoomBookingService
ServiceLayer .. NotificationManagementService
PersistenceLayer .. StudentGroupRepository
PersistenceLayer .. ClassMeetingRepository
PersistenceLayer .. AttendanceRepository
PersistenceLayer .. GenericRepository

AuthenticationService --> PersistenceLayer
AttendanceReportService --> ClassMeetingRepository
AttendanceReportService --> AttendanceRepository
AttendanceRegistrationService --> AttendanceRepository
ScheduleGenerationService --> PersistenceLayer
EntityService --> GenericRepository
EntityService --> JpaTransactionManager
RoomService --|> EntityService
RoomBookingService --> PersistenceLayer
NotificationManagementService --|> EntityService
NotificationManagementService --> NotificationRepository
StudentGroupRepository --> DomainLayer
ClassMeetingRepository --> DomainLayer
AttendanceRepository --> DomainLayer
GenericRepository --> JpaUtil
GenericRepository --> JpaTransactionManager

note bottom of GuiLayer
The current JavaFX code builds views inside AttendanceGuiApp.
Role-based navigation makes Student, Teacher, and Administrator
functions visibly different during defence.
end note

note bottom of StudentGroupRepository
MAS 4.2.4 is implemented by findAllWithStudents()
and StudentGroup.getStudents() in GroupStudentsAssociationView.
end note

note bottom of PersistenceLayer
Manual JPA/Hibernate repositories are used.
Spring is not used.
end note

@enduml
